<Window x:Class="TanulokJegyei.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TanulokJegyei"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="201*"/>
            <ColumnDefinition Width="599*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Átlagok" FontSize="44"
                   HorizontalAlignment="Left" Margin="124,30,0,134"
                   Grid.Column="1" Grid.RowSpan="2"/>

        <DataGrid x:Name="dataGrid" Grid.Row="1"
                  ItemsSource="{Binding Reservations, Mode=TwoWay}"
                  SelectedItem="{Binding SelectedReservation, Mode=TwoWay}"
                  SelectedIndex="{Binding SelectedReservationIndex, Mode=TwoWay}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Margin="10" HeadersVisibility="Column"
                  Grid.ColumnSpan="2">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Név" Binding="{Binding Name}" Width="2*"/>
                <DataGridTextColumn Header="Osztály" Binding="{Binding Class}" Width="*"/>
                <DataGridTextColumn Header="Matek" Binding="{Binding Math}" Width="*"/>
                <DataGridTextColumn Header="Fizika" Binding="{Binding Physics}" Width="*"/>
                <DataGridTextColumn Header="Átlag" Binding="{Binding Average}" Width="*"/>

                <DataGridTemplateColumn Header="Műveletek" Width="2*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="5,0,5,0">
                                <Button Content="Szerkesztés"
                                        Padding="6,2"
                                        Click="EditCommand"/>
                                <Button Content="Törlés"
                                        Padding="6,2"
                                        Margin="10,0,0,0"
                                        Click="DeleteCommand"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</Window>
