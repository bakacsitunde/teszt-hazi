<Window x:Class="TanulokJegyei.AddStudentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Új tanuló" Height="250" Width="350">

    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Név"/>
            <TextBox x:Name="nameBox" Margin="0,5" />

            <TextBlock Text="Osztály"/>
            <TextBox x:Name="classBox" Margin="0,5" />

            <TextBlock Text="Matek"/>
            <TextBox x:Name="mathBox" Margin="0,5" />

            <TextBlock Text="Fizika"/>
            <TextBox x:Name="physicsBox" Margin="0,5" />

            <Button Content="Hozzáadás" Margin="0,10,0,0" Click="Add_Click"/>
        </StackPanel>
    </Grid>
</Window>
