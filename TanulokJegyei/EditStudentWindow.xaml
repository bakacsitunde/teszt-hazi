<Window x:Class="TanulokJegyei.EditStudentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tanuló szerkesztése" Height="250" Width="350">

    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Név"/>
            <TextBox x:Name="nameBox" Margin="0,5" />

            <TextBlock Text="Osztály"/>
            <TextBox x:Name="classBox" Margin="0,5" />

            <TextBlock Text="Matek"/>
            <TextBox x:Name="mathBox" Margin="0,5" />

            <TextBlock Text="Fizika"/>
            <TextBox x:Name="physicsBox" Margin="0,5" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Mentés" Width="80" Margin="0,0,5,0" Click="Save_Click"/>
                <Button Content="Mégsem" Width="80" IsCancel="True"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
